und\" />\r\n                                        </button>\r\n                                    </div>\r\n\r\n                                    {/* Unread dot */}\r\n                                    {!notif.isRead && (\r\n                                        <div className={cn(\r\n                                            \"w-2 h-2 rounded-full shrink-0 mt-1.5\",\r\n                                            isBroadcast ? \"bg-primary\" : \"bg-primary\"\r\n                                        )} />\r\n                                    )}\r\n                                </div>\r\n                            );\r\n                        })\r\n                    )}\r\n                </div>\r\n            </DropdownMenuContent>\r\n        </DropdownMenu>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\components\\orders\\order-details-dialog.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\components\\pagination.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\components\\promotion\\promotion-display.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\components\\recently-viewed-dropdown.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\components\\recently-viewed.tsx","me