                                </TableCell>\r\n                                        <TableCell>{getStatusBadge(request.status)}</TableCell>\r\n                                        <TableCell>\r\n                                            {request.eligibilityChecks.allPassed ? (\r\n                                                <Badge variant=\"default\" className=\"bg-green-600\">\r\n                                                    ✓ Eligible\r\n                                                </Badge>\r\n                                            ) : (\r\n                                                <Badge variant=\"destructive\">✗ Not Eligible</Badge>\r\n                                            )}\r\n                                        </TableCell>\r\n                                        <TableCell className=\"text-sm text-gray-600\">\r\n                                            {formatDate(request.createdAt)}\r\n                                        </TableCell>\r\n                                        <TableCell className=\"text-right\">\r\n                                            {request.status === 'pending' && (\r\n                                                <Button\r\n                                                    variant=\"outline\"\r\n                                                    size=\"sm\"\r\n                                                    onClick={() => handleCancel(request._id)}\r\n                                                >\r\n                                                    Cancel\r\n                                                </Button>\r\n                                            )}\r\n                                            {request.status === 'rejected' && request.rejectionReason && (\r\n                                                <Badge variant=\"destructive\" className=\"text-xs\">\r\n                                                    {request.rejectionReason}\r\n                                                </Badge>\r\n                                            )}\r\n                                        </TableCell>\r\n                                    </TableRow>\r\n                                ))}\r\n                            </TableBody>\r\n                        </Table>\r\n                    )}\r\n                </CardContent>\r\n            </Card>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\pages\\seller\\revenue\\Revenue.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\pages\\seller\\reviews\\Reviews.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'ThumbsUp' is defined but never used.","line":5,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":5,"endColumn":11,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"ThumbsUp"},"fix":{"range":[73,86],"text":""},"desc":"Remove unused variable \"ThumbsUp\"."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":48,"column":19,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":48,"endColumn":22,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[1492,1495],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[1492,1495],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":74,"column":19,"nodeType":"TSAnyKeyword","messag