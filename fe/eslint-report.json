,{"messageId":"suggestNever","fix":{"range":[3449,3452],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":149,"column":76,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":149,"endColumn":79,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[6228,6231],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[6228,6231],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]},{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":310,"column":99,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":310,"endColumn":102,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[17708,17711],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[17708,17711],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters that you don't need to know the type of."}]}],"suppressedMessages":[],"errorCount":7,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"import { useEffect, useState } from \"react\";\r\nimport api from \"@/lib/axios\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Card } from \"@/components/ui/card\";\r\nimport { Textarea } from \"@/components/ui/textarea\";\r\nimport {\r\n    Dialog,\r\n    DialogContent,\r\n    DialogHeader,\r\n    DialogTitle,\r\n} from \"@/components/ui/dialog\";\r\nimport { toast } from \"sonner\";\r\nimport { Eye, CheckCircle2, AlertTriangle } from \"lucide-react\";\r\n\r\ntype RefundRequest = {\r\n    _id: string;\r\n    order: { _id: string; totalAmount: number; status: string; items?: any[] };\r\n    buyer: { _id: string; username: string };\r\n    reason: string;\r\n    description: string;\r\n    faultType: string;\r\n    status: string;\r\n    requestedAt: string;\r\n    sellerNote?: string;\r\n    adminNote?: string;\r\n    images?: string[];\r\n};\r\n\r\nexport default function SellerRefunds() {\r\n    const [refunds, setRefunds] = useState<RefundRequest[]>([]);\r\n    const [loading, setLoading] = useState(true);\r\n    const [page] = useState(1);\r\n\r\n    // Dialog state\r\n    const [selectedRefund, setSelectedRefund] = useState<RefundRequest | null>(null);\r\n    const [isDialogOpen, setIsDialogOpen] = useState(false);\r\n    const [sellerNote, setSellerNote] = useState(\"\");\r\n    const [pendingAction, setPendingAction] = useState<\"APPROVE\" | \"REJECT\" | \"CONFIRM_RECEIPT\" | null>(null);\r\n    const [submitting, setSubmitting] = useState(false);\r\n    const [returnCondition, setReturnCondition] = useState<\"SELLABLE\" | \"OPENED\" | \"DAMAGED\">(\"SELLABLE\");\r\n\r\n    useEffect(() => {\r\n        fetchRefunds();\r\n    }, [page]);\r\n\r\n    const fetchRefunds = async () => {\r\n        try {\r\n            setLoading(true);\r\n            const res = await api.get(`/api/refund/seller?page=${page}&limit=20`);\r\n            setRefunds(res.data.data || []);\r\n        } catch (err: any) {\r\n            toast.error(\"Failed to load refund requests\");\r\n        } finally {\r\n            setLoading(false);\r\n        }\r\n    };\r\n\r\n    const handleAction = async (actionType: \"APPROVE\" | \"REJECT\") => {\r\n        if (!selectedRefund) return;\r\n        if (actionType === \"REJECT\" && !sellerNote.trim()) {\r\n            toast.error(\"Please provide a reason for rejection.\");\r\n            return;\r\n        }\r\n\r\n        try {\r\n            setSubmitting(true);\r\n            setPendingAction(actionType);\r\n            const endpoint = actionType === \"APPROVE\" ? \"approve\" : \"reject\";\r\n            await api.post(`/api/refund/${selectedRefund._id}/${endpoint}`, {\r\n                sellerNote,\r\n            });\r\n\r\n            toast.success(`Refund ${actionType.toLowerCase()}d successfully`);\r\n            setIsDialogOpen(false);\r\n            fetchRefunds();\r\n        } catch (err: any) {\r\n            toast.error(err.response?.data?.message || `Failed to ${actionType.toLowerCase()} refund`);\r\n        } finally {\r\n            setSubmitting(false);\r\n            setPendingAction(null);\r\n        }\r\n    };\r\n\r\n    const handleConfirmReceipt = async () => {\r\n        if (!selectedRefund) return;\r\n        try {\r\n            setSubmitting(true);\r\n            setPendingAction(\"CONFIRM_RECEIPT\");\r\n            await api.post(`/api/refund/${selectedRefund._id}/confirm-receipt`, { condition: returnCondition });\r\n            toast.success(\"Return receipt confirmed successfully. Refund completed.\");\r\n            setIsDialogOpen(false);\r\n            fetchRefunds();\r\n        } catch (err: any) {\r\n            toast.error(err.response?.data?.message || \"Failed to confirm return receipt\");\r\n        } finally {\r\n            setSubmitting(false);\r\n            setPendingAction(null);\r\n        }\r\n    };\r\n\r\n    const getStatusTheme = (status: string) => {\r\n        switch (status) {\r\n            case \"PENDING\":\r\n                return { badge: \"secondary\", text: \"Pending Review\" };\r\n            case \"APPROVED\":\r\n            case \"AUTO_APPROVED\":\r\n            case \"ADMIN_APPROVED\":\r\n                return { badge: \"default\", text: \"Approved\" };\r\n            case \"REJECTED\":\r\n            case \"ADMIN_REJECTED\":\r\n                return { badge: \"destructive\", text: \"Rejected\" };\r\n            case \"DISPUTED\":\r\n                return { badge: \"warning\", text: \"Under Dispute\" };\r\n            case \"SELLER_RECEIVED_RETURN\":\r\n                return { badge: \"default\", text: \"Returned Successfully\" };\r\n            default:\r\n                return { badge: \"outline\", text: status };\r\n        }\r\n    };\r\n\r\n    return (\r\n        <div className=\"p-6\">\r\n            <h1 className=\"text-2xl font-bold mb-6\">Refund Requests</h1>\r\n\r\n            {loading ? (\r\n                <div className=\"flex h-40 items-center justify-center\">\r\n                    <div className=\"h-8 w-8 animate-spin rounded-full border-4 border-primary border-t-transparent\" />\r\n                </div>\r\n            ) : refunds.length === 0 ? (\r\n                <Card className=\"flex flex-col items-center justify-center py-16 text-muted-foreground\">\r\n                    <CheckCircle2 className=\"mb-4 h-12 w-12 text-muted-foreground/50\" />\r\n                    <h3 className=\"text-xl font-medium\">All clear!</h3>\r\n                    <p>No refund requests to review.</p>\r\n                </Card>\r\n            ) : (\r\n                <div className=\"grid gap-4\">\r\n                    {refunds.map((refund) => {\r\n                        const theme = getStatusTheme(refund.status);\r\n                        const firstItem = refund.order?.items?.[0];\r\n                        const productImg = firstItem?.productId?.images?.[0] || firstItem?.image || \"\";\r\n                        const productTitle = firstItem?.productId?.title || firstItem?.title || \"Unknown Product\";\r\n\r\n                        return (\r\n                            <Card key={refund._id} className=\"overflow-hidden border border-gray-200 shadow-sm hover:shadow-md transition-shadow\">\r\n                                <div className=\"p-5 flex flex-col md:flex-row justify-between md:items-center gap-4\">\r\n                                    <div className=\"flex-1 space-y-3\">\r\n                                        <div className=\"flex items-center gap-3\">\r\n                                            <Badge variant={theme.badge as any} className={theme.badge === 'warning' ? 'bg-amber-500 hover:bg-amber-600' : ''}>\r\n                                                {theme.text}\r\n                                            </Badge>\r\n                                            <span className=\"text-sm font-semibold\">\r\n                                                Order #{refund.order?._id?.slice(-8)?.toUpperCase() || \"N/A\"}\r\n                                            </span>\r\n                                            <span className=\"text-sm text-gray-500 whitespace-nowrap hidden sm:inline-block\">\r\n                                                {new Date(refund.requestedAt).toLocaleDateString()}\r\n                                            </span>\r\n                                        </div>\r\n                                        \r\n                                        <div className=\"flex items-start gap-3 mt-2 border p-3 rounded-lg bg-gray-50/50\">\r\n                                            {productImg ? (\r\n                                                <img src={productImg} alt=\"Product\" className=\"w-12 h-12 rounded object-cover flex-shrink-0 border bg-white\" />\r\n                                            ) : (\r\n                                                <div className=\"w-12 h-12 rounded bg-gray-100 flex items-center justify-center flex-shrink-0 border\">\r\n                                                    <span className=\"text-[10px] text-gray-400\">No img</span>\r\n                                                </div>\r\n                                            )}\r\n                                            <div className=\"flex flex-col\">\r\n                                                <span className=\"text-sm font-medium line-clamp-1\">{productTitle}</span>\r\n                                                <span className=\"text-xs text-gray-500 mt-1\">\r\n                                                    <span className=\"font-semibold text-gray-900\">{refund.buyer.username}</span> requested a return due to <span className=\"font-semibold text-gray-900 capitalize\">{refund.reason?.replace(/_/g, ' ')?.toLowerCase()}</span>\r\n                                                </span>\r\n                                            </div>\r\n                                        </div>\r\n\r\n                                        {refund.status === \"PENDING\" && (\r\n                                            <div className=\"flex items-center text-xs text-amber-600 font-medium bg-amber-50 w-fit px-2 py-1 rounded\">\r\n                                                <AlertTriangle className=\"w-3.5 h-3.5 justify-center mr-1\" />\r\n                                                Please respond within 48h to avoid auto-approval impacting trust score.\r\n                                            </div>\r\n                                        )}\r\n                                    </div>\r\n                                    <div className=\"flex flex-col items-end gap-2 min-w-max\">\r\n                                        <span className=\"text-xs text-gray-400 sm:hidden\">\r\n                                            {new Date(refund.requestedAt).toLocaleDateString()}\r\n                                        </span>\r\n                                        <Button\r\n                                            variant=\"outline\"\r\n                                            size=\"sm\"\r\n                                            className=\"hover:bg-blue-50 hover:text-blue-600 transition-colors\"\r\n                                            onClick={() => {\r\n                                                setSelectedRefund(refund);\r\n                                                setIsDialogOpen(true);\r\n                                                setSellerNote(refund.sellerNote || \"\");\r\n                                            }}\r\n                                        >\r\n                                            <Eye className=\"w-4 h-4 mr-2\" />\r\n                                            View Details\r\n                                        </Button>\r\n                                    </div>\r\n                                </div>\r\n                            </Card>\r\n                        )\r\n                    })}\r\n                </div>\r\n            )}\r\n\r\n            <Dialog open={isDialogOpen} onOpenChange={setIsDialogOpen}>\r\n                <DialogContent className=\"max-w-2xl\">\r\n                    <DialogHeader>\r\n                        <DialogTitle>Refund Request Details</DialogTitle>\r\n                    </DialogHeader>\r\n                    {selectedRefund && (\r\n                        <div className=\"space-y-6\">\r\n                            <div className=\"grid grid-cols-2 gap-4 text-sm bg-muted p-4 rounded-lg\">\r\n                                <div>\r\n                                    <p className=\"text-muted-foreground\">Order ID</p>\r\n                                    <p className=\"font-medium flex items-center gap-2\">\r\n                                        {selectedRefund.order._id}\r\n                                    </p>\r\n                                </div>\r\n                                <div>\r\n                                    <p className=\"text-muted-foreground\">Reason</p>\r\n                                    <p className=\"font-medium\">{selectedRefund.reason}</p>\r\n                                </div>\r\n                                <div className=\"col-span-2 mt-2\">\r\n                                    <p className=\"text-muted-foreground\">Buyer's Comment</p>\r\n                                    <p className=\"p-3 bg-background rounded border mt-1 font-medium\">{selectedRefund.description}</p>\r\n                                </div>\r\n                            </div>\r\n\r\n                            {selectedRefund.images && selectedRefund.images.length > 0 && (\r\n                                <div className=\"space-y-2 mt-4\">\r\n                                    <p className=\"font-semibold text-sm\">Evidence Images</p>\r\n                                    <div className=\"flex flex-wrap gap-3\">\r\n                                        {selectedRefund.images.map((url, idx) => (\r\n                                            <div key={idx} className=\"w-24 h-24 rounded overflow-hidden border bg-muted group relative\">\r\n                                                <img \r\n                                                    src={url} \r\n                                                    alt=\"Evidence\" \r\n                                                    className=\"w-full h-full object-cover transition-transform hover:scale-105 cursor-pointer\"\r\n                                                    onClick={() => window.open(url, \"_blank\")}\r\n                                                />\r\n                                            </div>\r\n                                        ))}\r\n                                    </div>\r\n                                    <p className=\"text-xs text-muted-foreground mt-1\">Click on an image to view full size</p>\r\n                                </div>\r\n                            )}\r\n\r\n                            {selectedRefund.status !== \"PENDING\" && (\r\n                                <div className=\"text-sm bg-muted/50 p-4 rounded-lg border\">\r\n                                    <p className=\"text-muted-foreground\">Your Response</p>\r\n                                    <p className=\"font-medium\">{selectedRefund.sellerNote || \"No message provided.\"}</p>\r\n                                </div>\r\n                            )}\r\n\r\n                            {selectedRefund.adminNote && (\r\n                                <div className=\"text-sm bg-primary/10 p-4 rounded-lg border border-primary/20\">\r\n                                    <p className=\"font-semibold text-primary pb-1\">Admin Verdict</p>\r\n                                    <p>{selectedRefund.adminNote}</p>\r\n                                </div>\r\n                            )}\r\n\r\n                            {selectedRefund.status === \"PENDING\" && (\r\n                                <div className=\"space-y-4 pt-4 border-t\">\r\n                                    <div>\r\n                                        <h4 className=\"font-medium mb-2\">Reply to buyer</h4>\r\n                                        <Textarea\r\n                                            placeholder=\"Provide instructions for return or a reason for rejection...\"\r\n                                            value={sellerNote}\r\n                                            onChange={(e) => setSellerNote(e.target.value)}\r\n                                            rows={3}\r\n                                            className=\"resize-none\"\r\n                                        />\r\n                                    </div>\r\n                                    <div className=\"flex justify-end gap-3 pt-4\">\r\n                                        <Button\r\n                                            variant=\"destructive\"\r\n                                            onClick={() => handleAction(\"REJECT\")}\r\n                                            disabled={submitting}\r\n                                        >\r\n                                            {submitting && pendingAction === \"REJECT\" ? \"Processing...\" : \"Reject Request\"}\r\n                                        </Button>\r\n                                        <Button\r\n                                            className=\"bg-green-600 hover:bg-green-700\"\r\n                                            onClick={() => handleAction(\"APPROVE\")}\r\n                                            disabled={submitting}\r\n                                        >\r\n                                            {submitting && pendingAction === \"APPROVE\" ? \"Processing...\" : \"Approve Return\"}\r\n                                        </Button>\r\n                                    </div>\r\n                                </div>\r\n                            )}\r\n\r\n                            {[\"APPROVED\", \"AUTO_APPROVED\", \"ADMIN_APPROVED\"].includes(selectedRefund.status) && selectedRefund.order?.status === \"delivered_to_seller\" && (\r\n                                <div className=\"space-y-4 pt-4 border-t\">\r\n                                    <div className=\"bg-blue-50 text-blue-800 p-4 rounded-lg flex items-start gap-2\">\r\n                                        <CheckCircle2 className=\"w-5 h-5 mt-0.5 flex-shrink-0\" />\r\n                                        <div>\r\n                                            <p className=\"font-medium\">Shipper has returned the package to you.</p>\r\n                                            <p className=\"text-sm mt-1\">Please inspect the item and choose its condition to process the final refund. Inventory will only restock if marked as SELLABLE.</p>\r\n                                        </div>\r\n                                    </div>\r\n                                    <div className=\"flex flex-col gap-2\">\r\n                                        <label className=\"text-sm font-semibold\">Received Item Condition</label>\r\n                                        <select \r\n                                            className=\"w-full xl:w-1/2 p-2 border rounded-md 