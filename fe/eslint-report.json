      Your product needs to be listed for at least 60 days. Wait{' '}\r\n                                    {60 - listingAge} more days.\r\n                                </p>\r\n                            </div>\r\n                        )}\r\n                    </div>\r\n\r\n                    {/* Submit */}\r\n                    <div className=\"flex justify-end gap-2 pt-4\">\r\n                        <Button type=\"button\" variant=\"outline\" onClick={onClose}>\r\n                            Cancel\r\n                        </Button>\r\n                        <Button\r\n                            type=\"submit\"\r\n                            disabled={\r\n                                loading ||\r\n                                !discountedPrice ||\r\n                                discountedPrice >= originalPrice ||\r\n                                discountPercent < 30\r\n                            }\r\n                        >\r\n                            {loading ? 'Submitting...' : 'Submit Request'}\r\n                        </Button>\r\n                    </div>\r\n                </form>\r\n            </DialogContent>\r\n        </Dialog>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\components\\seller\\seller-information.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'ScrollArea' is defined but never used.","line":8,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":8,"endColumn":20,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"ScrollArea"},"fix":{"range":[353,410],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"@typescript-eslint/no-unused-vars","severity":2,"message":"'CheckCircle' is defined but never used.","line":11,"column":3,"nodeType":"Identifier","messageId":"unusedVar","endLine":11,"endColumn":14,"suggestions":[{"messageId":"removeUnusedVar","data