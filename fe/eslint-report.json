 {/* Username */}\r\n                  <div className=\"space-y-2\">\r\n                    <Label htmlFor=\"username\">Username</Label>\r\n                    <Input\r\n                      id=\"username\"\r\n                      value={newUsername}\r\n                      onChange={(e) => setNewUsername(e.target.value)}\r\n                      placeholder=\"Enter username\"\r\n                    />\r\n                  </div>\r\n                </div>\r\n\r\n                <div className=\"flex gap-2 justify-end\">\r\n                  <AlertDialogCancel\r\n                    className=\"cursor-pointer\"\r\n                    onClick={handleCancelEditProfile}\r\n                  >\r\n                    Cancel\r\n                  </AlertDialogCancel>\r\n                  <AlertDialogAction\r\n                    className=\"cursor-pointer bg-[#AAED56] text-[#324E0F] hover:bg-[#8feb1d]\"\r\n                    onClick={handleUpdateProfile}\r\n                    disabled={loading}\r\n                  >\r\n                    {loading ? \"Saving...\" : \"Save Changes\"}\r\n                  </AlertDialogAction>\r\n                </div>\r\n              </AlertDialogContent>\r\n            </AlertDialog>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n\r\n      <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">\r\n        {/* Section 2: Email & Password (Left) */}\r\n        <div className=\"lg:col-span-1 space-y-6\">\r\n          {/* Email Card */}\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg\">Email</CardTitle>\r\n            </CardHeader>\r\n            <CardContent className=\"space-y-4\">\r\n              {!editEmail ? (\r\n                <>\r\n                  <div className=\"p-3 bg-gray-50 rounded-md text-gray-700\">\r\n                    {user.email}\r\n                  </div>\r\n\r\n                  {user.provider !== \"google\" && (\r\n                    <Button\r\n                      variant=\"outline\"\r\n                      className=\"w-full cursor-pointer\"\r\n                      onClick={() => setEditEmail(true)}\r\n                    >\r\n                      Change Email\r\n                    </Button>\r\n                  )}\r\n\r\n                  {user.provider === \"google\" && (\r\n                    <p className=\"text-sm text-gray-500\">\r\n                      You cannot change your email because you signed up with\r\n                      Google. Please manage your email through your Google\r\n                      account settings.\r\n                    </p>\r\n                  )}\r\n                </>\r\n              ) : (\r\n                <Form {...form}>\r\n                  <form\r\n                    onSubmit={form.handleSubmit(onEmailSubmit)}\r\n                    className=\"space-y-4\"\r\n                  >\r\n                    <FormField\r\n                      control={form.control}\r\n                      name=\"email\"\r\n                      render={({ field }) => (\r\n                        <FormItem>\r\n                          <FormLabel>New email</FormLabel>\r\n                          <FormControl>\r\n                            <Input placeholder=\"Enter new email\" {...field} />\r\n                          </FormControl>\r\n                          <FormMessage />\r\n                        </FormItem>\r\n                      )}\r\n                    />\r\n\r\n                    <div className=\"flex gap-2\">\r\n                      <Button\r\n                        type=\"submit\"\r\n                        disabled={loading}\r\n                        className=\"flex-1 cursor-pointer bg-[#AAED56] text-[#324E0F] hover:bg-[#8feb1d]\"\r\n                      >\r\n                        {loading ? \"Saving...\" : \"Save Email\"}\r\n                      </Button>\r\n\r\n                      <Button\r\n                        type=\"button\"\r\n                        variant=\"outline\"\r\n                        onClick={() => {\r\n                          setEditEmail(false);\r\n                          form.reset({ email: user.email });\r\n                        }}\r\n                        className=\"flex-1 cursor-pointer\"\r\n                      >\r\n                        Cancel\r\n                      </Button>\r\n                    </div>\r\n                  </form>\r\n                </Form>\r\n              )}\r\n            </CardContent>\r\n          </Card>\r\n\r\n          {/* Password Card */}\r\n          <Card>\r\n            <CardHeader>\r\n              <CardTitle className=\"text-lg\">Password</CardTitle>\r\n            </CardHeader>\r\n            <CardContent>\r\n              <AlertDialog\r\n                open={changePassOpen}\r\n                onOpenChange={setChangePassOpen}\r\n              >\r\n                <AlertDialogTrigger asChild>\r\n                  <Button variant=\"outline\" className=\"w-full cursor-pointer\">\r\n                    Change Password\r\n                  </Button>\r\n                </AlertDialogTrigger>\r\n                <AlertDialogContent className=\"max-w-md\">\r\n                  <AlertDialogTitle>Change Password</AlertDialogTitle>\r\n                  <AlertDialogDescription>\r\n                    Enter your current password and a new password to change it.\r\n                  </AlertDialogDescription>\r\n\r\n                  <Form {...passwordForm}>\r\n                    <form\r\n                      onSubmit={passwordForm.handleSubmit(\r\n                        onChangePasswordSubmit,\r\n                      )}\r\n                      className=\"space-y-4 py-4\"\r\n                    >\r\n                      <FormField\r\n                        control={passwordForm.control}\r\n                        name=\"currentPassword\"\r\n                        render={({ field }) => (\r\n                          <FormItem>\r\n                            <FormLabel>Current Password</FormLabel>\r\n                            <FormControl>\r\n                              <Input\r\n                                type=\"password\"\r\n                                placeholder=\"Enter current password\"\r\n                                {...field}\r\n                              />\r\n                            </FormControl>\r\n                            <FormMessage />\r\n                          </FormItem>\r\n                        )}\r\n                      />\r\n\r\n                      <FormField\r\n                        control={passwordForm.control}\r\n                        name=\"newPassword\"\r\n                        render={({ field }) => (\r\n                          <FormItem>\r\n                            <FormLabel>New Password</FormLabel>\r\n                            <FormControl>\r\n                              <Input\r\n                                type=\"password\"\r\n                                placeholder=\"Enter new password\"\r\n                                {...field}\r\n                              />\r\n                            </FormControl>\r\n                            <FormMessage />\r\n                          </FormItem>\r\n                        )}\r\n                      />\r\n\r\n                      <FormField\r\n                        control={passwordForm.control}\r\n                        name=\"confirmPassword\"\r\n                        render={({ field }) => (\r\n                          <FormItem>\r\n                            <FormLabel>Confirm Password</FormLabel>\r\n                            <FormControl>\r\n                              <Input\r\n                                type=\"password\"\r\n                                placeholder=\"Confirm new password\"\r\n                                {...field}\r\n                              />\r\n                            </FormControl>\r\n                            <FormMessage />\r\n                          </FormItem>\r\n                        )}\r\n                      />\r\n\r\n                      <div className=\"flex gap-2 justify-end\">\r\n                        <AlertDialogCancel\r\n                          className=\"cursor-pointer\"\r\n                          onClick={() => passwordForm.reset()}\r\n                        >\r\n                          Cancel\r\n                        </AlertDialogCancel>\r\n                        <Button\r\n                          type=\"submit\"\r\n                          className=\"cursor-pointer bg-[#AAED56] text-[#324E0F] hover:bg-[#8feb1d]\"\r\n                          disabled={loading}\r\n                        >\r\n                          {loading ? \"Saving...\" : \"Save Password\"}\r\n                        </Button>\r\n                      </div>\r\n                    </form>\r\n                  </Form>\r\n                </AlertDialogContent>\r\n              </AlertDialog>\r\n            </CardContent>\r\n          </Card>\r\n        </div>\r\n\r\n        {/* Section 3: User Address */}\r\n        <div className=\"lg:col-span-2\">\r\n          <Card>\r\n            <CardHeader>\r\n              <div className=\"flex items-center justify-between\">\r\n                <CardTitle className=\"text-lg\">Address</CardTitle>\r\n                {Array.isArray(addresses) && addresses.length >= 1 && (\r\n                  <Button\r\n                    className=\"cursor-pointer bg-[#AAED56] text-[#324E0F] hover:bg-[#8feb1d]\"\r\n                    onClick={() => setIsModalOpen(true)}\r\n                  >\r\n                    Add Address\r\n                  </Button>\r\n                )}\r\n              </div>\r\n              <CardDescription>\r\n                Your saved addresses will appear here.\r\n              </CardDescription>\r\n            </CardHeader>\r\n            {!loading && addresses.length === 0 && (\r\n  