-reply-dialog';\r\n\r\nexport default function SellerFeedbackPage() {\r\n    const navigate = useNavigate();\r\n    const [reviews, setReviews] = useState<any[]>([]);\r\n    const [loading, setLoading] = useState(true);\r\n    const [replyDialogOpen, setReplyDialogOpen] = useState(false);\r\n    const [selectedReview, setSelectedReview] = useState<any>(null);\r\n\r\n    useEffect(() => {\r\n        loadReviews();\r\n    }, []);\r\n\r\n    const loadReviews = async () => {\r\n        try {\r\n            // Get all reviews where current user is the seller\r\n            const res = await api.get('/api/reviews/seller/my-reviews');\r\n            setReviews(res.data.data || []);\r\n        } catch (err: any) {\r\n            console.error(err);\r\n            toast.error('Failed to load feedback');\r\n        } finally {\r\n            setLoading(false);\r\n        }\r\n    };\r\n\r\n    const handleRequestRevision = (reviewId: string) => {\r\n        navigate(`/seller/feedback-revision-request/${reviewId}`);\r\n    };\r\n\r\n    const handleReply = (review: any) => {\r\n        setSelectedReview(review);\r\n        setReplyDialogOpen(true);\r\n    };\r\n\r\n    const handleReplySuccess = () => {\r\n        loadReviews(); // Reload to show updated response\r\n    };\r\n\r\n    const getTypeColor = (type: string) => {\r\n        switch (type) {\r\n            case 'positive':\r\n                return 'bg-green-50 text-green-700 border-green-200';\r\n            case 'neutral':\r\n                return 'bg-yellow-50 text-yellow-700 border-yellow-200';\r\n            case 'negative':\r\n                return 'bg-red-50 text-red-700 border-red-200';\r\n            default:\r\n                return 'bg-gray-50 text-gray-700 border-gray-200';\r\n        }\r\n    };\r\n\r\n    const renderStars = (rating: number) => {\r\n        return (\r\n            <div className=\"flex items-center gap-1\">\r\n                {[1, 2, 3, 4, 5].map((star) => (\r\n                    <Star\r\n                        key={star}\r\n                        className={`w-4 h-4 ${star <= rating\r\n                            ? 'fill-yellow-400 text-yellow-400'\r\n                            : 'text-gray-300'\r\n                            }`}\r\n                    />\r\n                ))}\r\n                <span className=\"ml-2 text-sm text-muted-foreground\">({rating}/5)</span>\r\n            </div>\r\n        );\r\n    };\r\n\r\n    const positiveReviews = reviews.filter(r => r.type === 'positive');\r\n    const neutralReviews = reviews.filter(r => r.type === 'neutral');\r\n    const negativeReviews = reviews.filter(r => r.type === 'negative');\r\n\r\n    if (loading) {\r\n        return (\r\n            <div className=\"p-6 max-w-7xl mx-auto\">\r\n                <p className=\"text-center text-muted-foreground\">Loading...</p>\r\n            </div>\r\n        );\r\n    }\r\n\r\n    return (\r\n        <div className=\"p-6 max-w-7xl mx-auto\">\r\n            <Card>\r\n                <CardHeader>\r\n                    <div className=\"flex items-center justify-between\">\r\n                        <CardTitle className=\"text-2xl font-bold flex items-center gap-2\">\r\n                            <MessageSquare className=\"w-6 h-6\" />\r\n                            Feedback Received\r\n                            <Badge variant=\"secondary\" className=\"ml-2\">\r\n                                {reviews.length}\r\n                            </Badge>\r\n                        </CardTitle>\r\n                        <Button\r\n                            variant=\"outline\"\r\n                            onClick={() => navigate('/seller/feedback-requests')}\r\n                        >\r\n                            View Revision Requests\r\n                        </Button>\r\n                    </div>\r\n                </CardHeader>\r\n\r\n                <CardContent>\r\n                    {reviews.length === 0 ? (\r\n                        <div className=\"text-center py-12\">\r\n                            <AlertCircle className=\"w-12 h-12 mx-auto text-muted-foreground mb-4\" />\r\n                            <p className=\"text-muted-foreground\">No feedback received yet</p>\r\n                        </div>\r\n                    ) : (\r\n                        <Tabs defaultValue=\"all\">\r\n                            <TabsList>\r\n                                <TabsTrigger value=\"all\">\r\n                                    All ({reviews.length})\r\n                                </TabsTrigger>\r\n                                <TabsTrigger value=\"positive\">\r\n                                    Positive ({positiveReviews.length})\r\n                                </TabsTrigger>\r\n                                <TabsTrigger value=\"neutral\">\r\n                                    Neutral ({neutralReviews.length})\r\n                                </TabsTrigger>\r\n                                <TabsTrigger value=\"negative\">\r\n                                    Negative ({negativeReviews.length})\r\n                                </TabsTrigger>\r\n                            </TabsList>\r\n\r\n                            <TabsContent value=\"all\" className=\"mt-6\">\r\n                                {renderReviewsTable(reviews)}\r\n                            </TabsContent>\r\n\r\n                            <TabsContent value=\"positive\" className=\"mt-6\">\r\n                                {renderReviewsTable(positiveReviews)}\r\n                            </TabsContent>\r\n\r\n                            <TabsContent value=\"neutral\" className=\"mt-6\">\r\n                                {renderReviewsTable(neutralReviews)}\r\n                            </TabsContent>\r\n\r\n                            <TabsContent value=\"negative\" className=\"mt-6\">\r\n                                {renderReviewsTable(negativeReviews)}\r\n                            </TabsContent>\r\n                        </Tabs>\r\n                    )}\r\n                </CardContent>\r\n            </Card>\r\n\r\n            {/* Seller Reply Dialog */}\r\n            {selectedReview && (\r\n                <SellerReplyDialog\r\n                    review={selectedReview}\r\n                    open={replyDialogOpen}\r\n                    onOpenChange={setReplyDialogOpen}\r\n                    onSuccess={handleReplySuccess}\r\n                />\r\n            )}\r\n        </div>\r\n    );\r\n\r\n    function renderReviewsTable(reviewList: any[]) {\r\n        if (reviewList.length === 0) {\r\n            return (\r\n                <div className=\"text-center py-8 text-muted-foreground\">\r\n                    No feedback in this category\r\n                </div>\r\n            );\r\n        }\r\n\r\n        return (\r\n            <div className=\"rounded-lg border\">\r\n                <Table>\r\n                    <TableHeader>\r\n                        <TableRow className=\"bg-gray-50/50\">\r\n                            <TableHead>Buyer</TableHead>\r\n                            <TableHead>Rating</TableHead>\r\n                            <TableHead>Type</TableHead>\r\n                            <TableHead>Comment & Response</TableHead>\r\n                            <TableHead>Date</TableHead>\r\n                            <TableHead>Status</TableHead>\r\n                            <TableHead>Actions</TableHead>\r\n                        </TableRow>\r\n                    </TableHeader>\r\n                    <TableBody>\r\n                        {reviewList.map((review) => (\r\n                            <TableRow key={review._id}>\r\n                                <TableCell>\r\n                                    <div className=\"flex items-center gap-2\">\r\n                                        <div className=\"w-8 h-8 bg-primary/10 rounded-full flex items-center justify-center\">\r\n                                            <span className=\"text-xs font-medium text-primary\">\r\n                                                {review.reviewer?.username?.charAt(0).toUpperCase() || 'B'}\r\n                                            </span>\r\n                                        </div>\r\n                                        <span className=\"font-medium\">\r\n                                            {review.reviewer?.username || 'Unknown'}\r\n                                        </span>\r\n                                    </div>\r\n                                </TableCell>\r\n                                <TableCell>\r\n                                    {renderStars(review.rating)}\r\n                                </TableCell>\r\n                                <TableCell>\r\n                                    <Badge variant=\"outline\" className={getTypeColor(review.type)}>\r\n                                        {review.type}\r\n                                    </Badge>\r\n                                </TableCell>\r\n                                <TableCell className=\"max-w-xs\">\r\n                                    <div className=\"truncate\" title={review.comment}>\r\n                                        {review.comment || 'No comment'}\r\n                                    </div>\r\n                                    {review.revisedAt && (\r\n                                        <Badge variant=\"outline\" className=\"mt-1 text-xs\">\r\n                                            Revised\r\n                                        </Badge>\r\n                                    )}\r\n                                    {/* Show seller reply if exists */}\r\n                                    {review.sellerResponse && (\r\n                                        <div className=\"mt-2 p-2 bg-blue-50 border border-blue-100 rounded text-xs\">\r\n                                            <span className=\"font-semibold text-blue-700 block mb-0.5\">Your reply:</span>\r\n                                            <span className=\"text-gray-700 line-clamp-2\">{review.sellerResponse}</span>\r\n                                        </div>\r\n                                    )}\r\n                                </TableCell>\r\n                                <TableCell className=\"text-sm text-gray-600\">\r\n                                    {formatDateTime(review.createdAt)}\r\n                                </TableCell>\r\n                                <TableCell>\r\n                                    {review.revisionRequested ? (\r\n                                        <Badge variant=\"secondary\">\r\n                                            Revision Requested\r\n                                        </Badge>\r\n                                    ) : (\r\n                                        <Badge variant=\"outline\">Active</Badge>\r\n                                    )}\r\n                                </TableCell>\r\n                                <TableCell>\r\n                                    <div className=\"flex gap-2\">\r\n                                        {/* Reply Button - show for all reviews */}\r\n                                        <Button\r\n                                            size=\"sm\"\r\n                                            variant={review.sellerResponse ? \"secondary\" : \"default\"}\r\n                                            onClick={() => handleReply(review)}\r\n                                            className=\"gap-1\"\r\n                                        >\r\n                                            <MessageCircle className=\"w-3 h-3\" />\r\n                                            {review.sellerResponse ? 'Edit Reply' : 'Reply'}\r\n                                        </Button>\r\n\r\n                                        {/* Request Revision Button */}\r\n                                        {!review.revisionRequested && (\r\n                                            <Button\r\n                                                size=\"sm\"\r\n                                                variant=\"outline\"\r\n                                                onClick={() => handleRequestRevision(review._id)}\r\n                                                className=\"text-primary hover:text-primary/80\"\r\n                                            >\r\n                                                Request Revision\r\n                                            </Button>\r\n                                        )}\r\n                                        {review.revisionRequested && (\r\n                                            <span className=\"text-xs text-muted-foreground\">\r\n                                                Revision requested\r\n                                            </span>\r\n                                        )}\r\n                                    </div>\r\n                                </TableCell>\r\n                            </TableRow>\r\n                        ))}\r\n                    </TableBody>\r\n                </Table>\r\n            </div>\r\n        );\r\n    }\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\Administrator\\Documents\\WDP\\fe\\src\\pages\\seller\\orders\\Complaints.tsx","messages":[{"ruleId":"@typescript-eslint/no-explicit-any","severity":2,"message":"Unexpected any. Specify a different type.","line":13,"column":50,"nodeType":"TSAnyKeyword","messageId":"unexpectedAny","endLine":13,"endColumn":53,"suggestions":[{"messageId":"suggestUnknown","fix":{"range":[578,581],"text":"unknown"},"desc":"Use `unknown` instead, this will force you to explicitly, and safely assert the type is correct."},{"messageId":"suggestNever","fix":{"range":[578,581],"text":"never"},"desc":"Use `never` instead, this is useful when instantiating generic type parameters th