<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8" />
  <title>Account Ban Notice</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f2f6f8;
      font-family: "Segoe UI", Arial, sans-serif;
    }

    .wrapper {
      width: 100%;
      padding: 30px 12px;
      background-color: #f2f6f8;
    }

    .container {
      max-width: 560px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    }

    .header {
      background: #b91c1c;
      padding: 20px;
      text-align: center;
      color: #ffffff;
    }

    .content {
      padding: 28px 24px;
      color: #1f2937;
      line-height: 1.6;
    }

    .reason {
      background: #fff7ed;
      border: 1px solid #fdba74;
      border-radius: 8px;
      padding: 12px;
      margin: 14px 0;
      color: #9a3412;
      font-size: 14px;
    }

    .btn-wrapper {
      text-align: center;
      margin: 24px 0;
    }

    .btn {
      display: inline-block;
      padding: 12px 22px;
      background: #dc2626;
      color: #ffffff !important;
      text-decoration: none;
      border-radius: 6px;
      font-size: 15px;
      font-weight: 600;
    }

    .link-box {
      background: #f8fafc;
      padding: 12px;
      border-radius: 6px;
      word-break: break-all;
      font-size: 13px;
      border: 1px dashed #cbd5e1;
      color: #334155;
    }

    .footer {
      padding: 16px 24px;
      background: #f8fafc;
      text-align: center;
      font-size: 12px;
      color: #64748b;
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="container">
      <div class="header">
        <h2 style="margin: 0;">Account Ban Notice</h2>
      </div>
      <div class="content">
        <p>Hello <strong><%= username %></strong>,</p>
        <p>Your account has been banned by an administrator.</p>
        <div class="reason">
          <strong>Reason:</strong> <%= reason %>
        </div>
        <p>
          If you believe this was a mistake, you can submit an appeal by using the link below.
        </p>
        <div class="btn-wrapper">
          <a href="<%= appealUrl %>" class="btn">Submit Appeal</a>
        </div>
        <p>If the button does not work, copy this link to your browser:</p>
        <div class="link-box"><%= appealUrl %></div>
        <p style="font-size: 13px; color: #64748b;">
          Appeal link expires at: <%= expiresAt %>
        </p>
      </div>
      <div class="footer">
        This email was sent automatically. Please do not reply.
      </div>
    </div>
  </div>
</body>

</html>
