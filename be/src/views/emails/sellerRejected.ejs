<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Đơn đăng ký Seller chưa được duyệt</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f2f6f8;
        font-family: "Segoe UI", Arial, sans-serif;
      }

      .wrapper {
        width: 100%;
        padding: 30px 12px;
        background-color: #f2f6f8;
      }

      .container {
        max-width: 520px;
        margin: 0 auto;
        background: #ffffff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
      }

      .header {
        background: #dc2626;
        padding: 20px;
        text-align: center;
        color: #ffffff;
      }

      .header h1 {
        margin: 0;
        font-size: 22px;
        font-weight: 600;
      }

      .content {
        padding: 28px 24px;
        color: #333333;
        line-height: 1.6;
      }

      .content h2 {
        margin-top: 0;
        font-size: 20px;
        color: #1f2937;
      }

      .content p {
        margin: 10px 0;
        font-size: 15px;
      }

      .note-box {
        background: #fef2f2;
        border-left: 4px solid #dc2626;
        padding: 12px 16px;
        border-radius: 4px;
        margin: 16px 0;
      }

      .footer {
        padding: 16px 24px;
        background: #f8fafc;
        text-align: center;
        font-size: 12px;
        color: #6b7280;
      }

      .footer p {
        margin: 4px 0;
      }
    </style>
  </head>

  <body>
    <div class="wrapper">
      <div class="container">
        <div class="header">
          <h1>YOUR SELLER APPLICATION HAS NOT BEEN APPROVED</h1>
        </div>
        <div class="content">
          <h2>Hello <%= username %></h2>
          <p>
            We have received your application to become a seller with the shop
            name <strong> <%= shopName %> </strong>.
          </p>
          <p>
            Unfortunately, your application has not been approved at this time.
          </p>

          <div class="note-box">
            <p style="margin: 0; font-size: 14px; color: #991b1b">
              <strong>Reason:</strong>
              <%= adminNote %>
            </p>
          </div>

          <p>
            You can update your information and resubmit your application after
            updating all the required information.
          </p>
          <p style="color: #6b7280; font-size: 13px">
            If you need further assistance, please contact our customer support
            team.
          </p>
        </div>
        <div class="footer">
          <p>
            &copy; <%= new Date().getFullYear() %> Ebay. All rights reserved.
          </p>
          <p>This email was sent automatically, please do not reply.</p>
        </div>
      </div>
    </div>
  </body>
</html>
