<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8" />
  <title>Appeal Result</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f2f6f8;
      font-family: "Segoe UI", Arial, sans-serif;
    }

    .wrapper {
      width: 100%;
      padding: 30px 12px;
    }

    .container {
      max-width: 560px;
      margin: 0 auto;
      background: #ffffff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
    }

    .header {
      padding: 20px;
      text-align: center;
      color: #ffffff;
      background: <%= decision === "approved" ? "#16a34a" : "#b91c1c" %>;
    }

    .content {
      padding: 24px;
      color: #1f2937;
      line-height: 1.6;
    }

    .note {
      background: #f8fafc;
      border: 1px solid #cbd5e1;
      border-radius: 8px;
      padding: 12px;
      margin-top: 12px;
      color: #334155;
      font-size: 14px;
      white-space: pre-wrap;
    }

    .btn {
      display: inline-block;
      margin-top: 18px;
      padding: 10px 18px;
      background: #1d4ed8;
      color: #ffffff !important;
      border-radius: 6px;
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="container">
      <div class="header">
        <h2 style="margin: 0;">Appeal Review Result</h2>
      </div>
      <div class="content">
        <p>Hello <strong><%= username %></strong>,</p>
        <% if (decision === "approved") { %>
          <p>Your account appeal has been approved. Your account is now active again.</p>
          <a href="<%= signInUrl %>" class="btn">Sign In</a>
        <% } else { %>
          <p>Your account appeal has been rejected at this time.</p>
        <% } %>
        <% if (note) { %>
          <p><strong>Admin note:</strong></p>
          <div class="note"><%= note %></div>
        <% } %>
      </div>
    </div>
  </div>
</body>

</html>
